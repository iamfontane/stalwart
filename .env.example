# Copy this file to .env and set your password before starting Stalwart:
#   cp .env.example .env
#   nano .env
#
# This password is used in two places:
#   1. Stalwart uses it as the fallback "admin" account password
#   2. Zencore reads it from config.json → stalwart_admin_pass
# Both must match exactly.

STALWART_ADMIN_SECRET=Evolv999
